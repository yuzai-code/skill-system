#!/usr/bin/env python3
"""skill-profile — evaluate a session profile and emit an offer if warranted.

Thin wrapper around lib.offer_runner.cmd_profile.
"""

from __future__ import annotations

import sys
from pathlib import Path

SYSTEM_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SYSTEM_ROOT))

from lib import offer_runner  # noqa: E402

if __name__ == "__main__":
    sys.exit(offer_runner.cmd_profile(sys.argv))
