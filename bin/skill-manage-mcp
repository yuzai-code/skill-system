#!/usr/bin/env python3
"""MCP server entry point — stdio transport.

Claude Code, Codex, and OpenCode all support MCP over stdio. The CLI
launches this script as a subprocess and pipes JSON-RPC over its
stdin/stdout.

Usage (configured in ~/.claude/.mcp.json):
  {
    "mcpServers": {
      "skill-system": {
        "command": "/Users/yuzai/.skill-system/bin/skill-manage-mcp",
        "args": [],
        "env": {"SKILLS_DIR": "/Users/yuzai/.claude/skills"}
      }
    }
  }
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

# Allow lib/ to be imported
SYSTEM_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SYSTEM_ROOT))

from lib import mcp_server  # noqa: E402


def main() -> int:
    skills_dir = os.environ.get("SKILLS_DIR")
    if skills_dir:
        return mcp_server.serve_stdio(Path(skills_dir))
    return mcp_server.serve_stdio()


if __name__ == "__main__":
    sys.exit(main())